# Ignore Visual Studio build output folders
**/bin/
**/obj/

# Ignore user-specific files and editor folders
*.user
*.suo
.vs/
.vscode/

# Ignore Git metadata and local gitignore (not needed in Docker context)
.git
.gitignore

# Ignore temporary and log files
*.log
*.tmp

# Ignore local environment files / secrets
.env
*.env
appsettings.Development.json
secrets/

# Ignore published output and artifacts
**/publish/
**/artifacts/

# Node modules (if any frontend parts are present)
node_modules/
